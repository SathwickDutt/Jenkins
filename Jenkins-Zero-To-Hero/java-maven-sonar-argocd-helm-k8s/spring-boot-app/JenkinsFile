pipeline {

    agent any

    environment {
        PROJECT_DIR = 'Jenkins-Zero-To-Hero/java-maven-sonar-argocd-helm-k8s/spring-boot-app'
        MANIFEST_DIR = 'Jenkins-Zero-To-Hero/java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests'
        SONAR_URL = 'http://65.2.69.210:9000'
        DOCKER_IMAGE = "sathwickdutt/ultimate-cicd:${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/SathwickDutt/Jenkins.git'
            }
        }

        stage('Build and Test') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                    dir("${PROJECT_DIR}") {
                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.login=$SONAR_AUTH_TOKEN \
                        -Dsonar.host.url=$SONAR_URL
                        '''
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh 'docker build -t ${DOCKER_IMAGE} .'
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
                        docker.image("${DOCKER_IMAGE}").push()
                    }
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                    sh '''
                    git config --global user.email "korrapatisathwickdutt@gmail.com"
                    git config --global user.name "Sathwick Dutt"

                    sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" \
                    ${MANIFEST_DIR}/deployment.yml

                    git add ${MANIFEST_DIR}/deployment.yml

                    git commit -m "Update deployment image to version ${BUILD_NUMBER}" || true

                    git push https://${GITHUB_TOKEN}@github.com/SathwickDutt/Jenkins.git HEAD:main
                    '''
                }
            }
        }
    }

    post {

        success {
            echo "Pipeline executed successfully."
        }

        failure {
            echo "Pipeline execution failed."
        }

        always {
            cleanWs()
        }
    }
}
